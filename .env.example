# GEMINI_API_KEY: Required for Gemini AI API calls (image analysis).
# Local development needs the VITE_ prefix to be exposed to the browser.
VITE_GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# IMGBB_API_KEY: Required for uploading deposit proof photos in the partner flow.
# Get a free key at https://api.imgbb.com/
VITE_IMGBB_API_KEY="YOUR_IMGBB_API_KEY"

# APP_URL: The URL where the app is hosted.
VITE_APP_URL="https://neurocycle.vercel.app"
