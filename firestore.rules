rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isSuperAdmin() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/superAdmins/$(request.auth.uid));
    }
    
    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.firebase.sign_in_provider == 'anonymous' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }
    
    function isPartner() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'partner';
    }
    
    function isOwner(userId: string) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isInstitutionAdmin(institutionId: string) {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'institution_admin' &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.institutionId == institutionId;
    }
    
    function getInstitutionId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.institutionId;
    }

    match /superAdmins/{adminId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    match /institutions/{institutionId} {
      allow read: if isAuthenticated();
      allow create: if isSuperAdmin();
      allow update: if isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin() || isSuperAdmin() || 
        isInstitutionAdmin(resource.data.institutionId));
      allow create: if isOwner(userId);
      allow update: if isAuthenticated() && (
        isSuperAdmin() || isAdmin() || isInstitutionAdmin(resource.data.institutionId) || (
          isOwner(userId) && 
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'points', 'level', 'isBanned', 'scanHistory', 'depositHistory', 'claimHistory', 'notifications'])
        )
      );
      allow delete: if isSuperAdmin() || isAdmin();
    }

    match /partners/{partnerId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || isAdmin() || isPartner() || 
        isInstitutionAdmin(resource.data.institutionId) || request.auth.uid == resource.data.ownerUid);
      allow create: if isAuthenticated() && (
        isSuperAdmin() || isAdmin() || isInstitutionAdmin(request.resource.data.institutionId) || (
          isOwner(request.resource.data.ownerUid) && 
          request.resource.data.status == 'pending'
        )
      );
      allow update: if isAuthenticated() && (
        isSuperAdmin() || isAdmin() || isInstitutionAdmin(resource.data.institutionId) || (
          isOwner(resource.data.ownerUid) && 
          request.resource.data.status == 'pending'
        )
      );
      allow delete: if isSuperAdmin() || isAdmin();
    }

    match /transactions/{txId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || isAdmin() || isPartner() || 
        isInstitutionAdmin(resource.data.institutionId));
      allow create: if isAuthenticated() && (
        isSuperAdmin() || isAdmin() || (
          isPartner() && 
          request.resource.data.partnerUid == request.auth.uid
        )
      );
      allow update, delete: if isSuperAdmin() || isAdmin() || isInstitutionAdmin(resource.data.institutionId);
    }

    match /adminReviews/{reviewId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && (isSuperAdmin() || isAdmin() || isPartner());
      allow update, delete: if isSuperAdmin() || isAdmin();
    }

    match /errorLogs/{logId} {
      allow read: if isSuperAdmin() || isAdmin() || isInstitutionAdmin(resource.data.institutionId);
      allow write: if isSuperAdmin() || isAdmin();
    }

    match /missions/{missionId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin() || isAdmin();
    }

    match /articles/{articleId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin() || isAdmin();
    }

    match /missionProgress/{progressId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isSuperAdmin() || isAdmin());
      allow write: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }

    match /missionProofs/{proofId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isSuperAdmin() || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isSuperAdmin() || isAdmin();
      allow delete: if isSuperAdmin() || isAdmin();
    }

    match /rewards/{rewardId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin() || isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
